<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LISTA -->
    <record id="view_pos_payment_correction_tree" model="ir.ui.view">
        <field name="name">pos.payment.correction.list</field>
        <field name="model">pos.payment.correction</field>
        <field name="arch" type="xml">

            <list create="0">
                <field name="fecha"/>
                <field name="usuario_solicitante_id"/>
                <field name="pos_config_id"/>
                <field name="pos_order_id"/>
                <field name="metodo_pago_anterior_id"/>
                <field name="metodo_pago_nuevo_id"/>
                <field name="monto"/>
                <field name="motivo"/>
                <field name="estado"/>
            </list>

        </field>
    </record>

    <!-- FORMULARIO -->
    <record id="view_pos_payment_correction_form" model="ir.ui.view">
        <field name="name">pos.payment.correction.form</field>
        <field name="model">pos.payment.correction</field>
        <field name="arch" type="xml">

            <form string="Corrección Método de Pago" edit="0">

            <header>

                <button name="action_aprobar_correccion"
                        type="object"
                        string="Aplicar corrección"
                        class="oe_highlight"
                        invisible="estado != 'draft'"/>

            </header>

                <sheet>

                    <group>
                        <field name="pos_order_id" readonly="1"/>
                        <field name="usuario_solicitante_id" readonly="1"/>
                        <field name="fecha" readonly="1"/>
                    </group>

                    <group>
                        <field name="metodo_pago_anterior_id" readonly="1"/>
                        <field name="metodo_pago_nuevo_id"/>
                        <field name="monto" readonly="1"/>
                    </group>

                    <group>
                        <field name="motivo"/>
                    </group>

                </sheet>

            </form>

        </field>
    </record>

        <!-- ACCION -->
    <record id="action_pos_payment_correction" model="ir.actions.act_window">
        <field name="context">{'create': False}</field>
        <field name="name">Correcciones de Pago POS</field>
        <field name="res_model">pos.payment.correction</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem
        id="menu_pos_payment_correction_root"
        name="Corrección Pagos POS"
        parent="point_of_sale.menu_point_root"
        action="action_pos_payment_correction"
        sequence="99"
        groups="point_of_sale.group_pos_manager"/>

    <record id="view_pos_order_form_payment_correction" model="ir.ui.view">
        <field name="name">pos.order.form.payment.correction</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form/header" position="inside">
                <button name="action_open_payment_correction"
                        type="object"
                        string="Corregir pago"
                        class="btn-secondary"
                        groups="point_of_sale.group_pos_manager"/>
            </xpath>

        </field>
    </record>    

</odoo>